# Copia este archivo como ".env" y complétalo.
# Mientras TBK_ENV no sea "production", el sistema corre en modo pruebas
# (sandbox) usando las credenciales públicas de integración de Transbank,
# así que puedes dejar todo esto vacío para probar el sitio.

PORT=3000

# URL pública donde vive tu sitio (index.html), usada para el retorno de pago
SITE_URL=http://localhost:8080

# Cambia a "production" SOLO cuando ya tengas tus credenciales reales de Transbank
TBK_ENV=integration

# Credenciales reales de Transbank (te las entregan al afiliarte como comercio)
TBK_COMMERCE_CODE=
TBK_API_KEY=
